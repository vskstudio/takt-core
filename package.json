{
  "name": "@vskstudio/takt-core",
  "version": "0.8.0",
  "description": "Tiny privacy-friendly analytics SDK for Takt",
  "license": "MIT",
  "author": "VSK Studio",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "analytics",
    "privacy",
    "tracking",
    "pageview",
    "takt"
  ],
  "homepage": "https://github.com/vskstudio/takt-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vskstudio/takt-core.git"
  },
  "bugs": {
    "url": "https://github.com/vskstudio/takt-core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/takt.js",
  "jsdelivr": "./dist/takt.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./snippet": "./dist/takt.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "size": "size-limit",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.0.0"
}
